{
  "mcpServers": {
    "turboquant-build": {
      "type": "stdio",
      "command": "cargo",
      "args": ["build", "--release"]
    },
    "turboquant-test": {
      "type": "stdio",
      "command": "cargo",
      "args": ["test", "--lib"]
    },
    "turboquant-bench": {
      "type": "stdio",
      "command": "cargo",
      "args": ["bench"]
    },
    "python-linter": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "pylint"],
      "cwd": "python"
    },
    "python-formatter": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "black", "--line-length", "100"]
    },
    "python-type-checker": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "mypy", "--ignore-missing-imports"],
      "cwd": "python"
    },
    "rust-format": {
      "type": "stdio",
      "command": "cargo",
      "args": ["fmt", "--all"]
    },
    "maturin-dev": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "maturin", "develop"],
      "env": {
        "CARGO_PROFILE_DEV_DEBUG": "line-tables-only"
      }
    }
  }
}
